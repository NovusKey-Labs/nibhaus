<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE. On API 31+ the SCAN/CONNECT runtime permissions replace location. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />

    <!-- Legacy BLE (API < 31). -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!-- The NeoLAB SDK's AAR declares this at maxSdkVersion=32; we cap it at 30 because our BLE
         scanning uses BLUETOOTH_SCAN + neverForLocation on Android 12+. tools:replace makes ours win. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30"
        tools:replace="android:maxSdkVersion" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Voice notes tied to a page (phone mic; audio stays in app-private storage, never uploaded). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Voice notes and touch are optional: don't let their implied features filter the app off the
         Play Store for mic-less / touchscreen-less (desktop/DeX-first) devices. -->
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- Create events in the user's existing device calendars (Google/Outlook) via CalendarContract.
         The app writes locally; the OS syncs to the account. No network calls from the app. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- Foreground service that owns the BLE pen connection (Phase 1, FIX #2). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />

    <!-- Lets us fire the direct "Allow" battery-optimization consent dialog
         (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS) instead of only routing through Settings — the
         Play-safe variant for an app whose core function is a background BLE link. See OemBattery. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:name=".NibhausApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Nibhaus"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nibhaus">

        <!-- Privacy (DESIGN.md no-telemetry rule): disable ML Kit / Firebase default usage &
             diagnostic logging to Google. On-device OCR (ML Kit Digital Ink) downloads its model
             on first use; nothing else is reported. -->
        <meta-data
            android:name="firebase_data_collection_default_enabled"
            android:value="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|density|uiMode"
            android:theme="@style/Theme.Nibhaus.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 0 spike activity moved to the debug manifest (src/debug) — it was exported
             production surface with no user value once Phase 0 cleared. -->

        <!-- Phase 1 — owns the BLE connection so capture survives backgrounding. -->
        <service
            android:name=".pen.PenForegroundService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Home-screen widget (#13): latest page + pen status, tap to jump back in. -->
        <receiver
            android:name=".widget.NibhausWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nibhaus_widget_info" />
        </receiver>

        <!-- Hands out cached PNG/PDF page renders as content:// URIs for Share / Email. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
