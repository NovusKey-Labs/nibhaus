<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy (Section C4): keep the note vault + secrets out of Google cloud-backup AND device-to-device
  transfer. Nibhaus is local-first — restore/migration is via Syncthing and the in-app encrypted
  backup, not Google's backup channel. Every private persistent store is excluded from both cloud
  backup and device transfer. API 31+.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="nibhaus.db" />
        <exclude domain="database" path="nibhaus.db-wal" />
        <exclude domain="database" path="nibhaus.db-shm" />
        <exclude domain="database" path="nibhaus.db-journal" />
        <exclude domain="sharedpref" path="nibhaus_secrets.xml" />
        <exclude domain="sharedpref" path="pen_prefs.xml" />
        <exclude domain="sharedpref" path="nibhaus_notebook_profiles.xml" />
        <exclude domain="sharedpref" path="nibhaus_zones.xml" />
        <exclude domain="sharedpref" path="nibhaus_backgrounds.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="recordings/" />  <!-- voice notes -->
        <exclude domain="file" path="exports/" />
        <exclude domain="file" path="crash/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="nibhaus.db" />
        <exclude domain="database" path="nibhaus.db-wal" />
        <exclude domain="database" path="nibhaus.db-shm" />
        <exclude domain="database" path="nibhaus.db-journal" />
        <exclude domain="sharedpref" path="nibhaus_secrets.xml" />
        <exclude domain="sharedpref" path="pen_prefs.xml" />
        <exclude domain="sharedpref" path="nibhaus_notebook_profiles.xml" />
        <exclude domain="sharedpref" path="nibhaus_zones.xml" />
        <exclude domain="sharedpref" path="nibhaus_backgrounds.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="recordings/" />  <!-- voice notes -->
        <exclude domain="file" path="exports/" />
        <exclude domain="file" path="crash/" />
    </device-transfer>
</data-extraction-rules>
